AI_PROVIDER=ollama
AI_MODEL=qwen2.5:3b
OLLAMA_BASE_URL=http://localhost:11434/v1
MCP_ROUTER_MODEL=qwen2.5:3b
ENABLE_MCP=true
ENABLE_EXTERNAL_MCP=true

# AWS values are read only when AI_PROVIDER=bedrock or AI_PROVIDER=sagemaker.
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-haiku-20241022-v1:0
SAGEMAKER_ENDPOINT_NAME=enterprise-assistant-hub-llm

# Hugging Face serverless inference is read only when AI_PROVIDER=hf.
HF_TOKEN=
HF_MODEL_ID=meta-llama/Llama-3.2-3B-Instruct

# Tests can point this at a temp file.
HUB_AUDIT_PATH=./audit_log.jsonl
