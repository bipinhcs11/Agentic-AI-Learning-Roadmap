# ============================================================
# .gitignore for project_03_aws_deployment
#
# WHAT: Files that must NOT be committed to git.
# WHY:  These files contain AWS account IDs, credentials,
#       generated state, or are too large/transient to track.
# ============================================================

# Terraform state files — contains your complete infrastructure
# description including any sensitive values. NEVER commit.
infrastructure/terraform.tfstate
infrastructure/terraform.tfstate.backup
infrastructure/.terraform/
infrastructure/.terraform.lock.hcl
infrastructure/tfplan
infrastructure/terraform.tfvars  # Contains your account ID and image URIs

# Auto-generated by ecr_setup.sh — contains account ID and repo URIs
.ecr_env

# macOS metadata files
.DS_Store
**/.DS_Store

# Editor files
.idea/
.vscode/
*.swp
*.swo
