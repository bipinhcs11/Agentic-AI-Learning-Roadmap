# ════════════════════════════════════════════════════════════════════════════
# AskMyDocs Pro — Environment Template
# WHY a template? docker-compose.yml is version-controlled, so secrets must NOT
# live there. Copy this file to .env and fill in real values:  cp .env.example .env
# docker-compose reads .env automatically and substitutes ${VAR} references.
# ════════════════════════════════════════════════════════════════════════════

# ─── Security ────────────────────────────────────────────────────────────────
# JWT signing key + super-admin token. Generate strong values:
#   openssl rand -hex 32   (run twice, one per key)
SECRET_KEY=change-me-run-openssl-rand-hex-32
SUPER_ADMIN_TOKEN=change-me-run-openssl-rand-hex-32

# ─── Ollama (local AI) ───────────────────────────────────────────────────────
# WHY host.docker.internal? Ollama runs on the host, not inside Docker. This
# hostname resolves to the host machine's IP from within a container.
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
AI_MODEL=gemma3:4b

# ─── Slack integration (optional) ────────────────────────────────────────────
# Signing secret from your Slack app's Basic Information page. Leave the default
# to run the /slack/ask endpoint in dev mode (signature verification skipped).
SLACK_SIGNING_SECRET=slack-prod-secret
