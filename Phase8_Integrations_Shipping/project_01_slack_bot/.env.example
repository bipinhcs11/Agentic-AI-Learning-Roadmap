# ─────────────────────────────────────────────────────────────────────────────
# Slack AI Bot — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Bot token — starts with xoxb-
# Found in: api.slack.com → Your App → OAuth & Permissions → Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-your-token-here

# App-level token — starts with xapp-
# Required for Socket Mode.
# Found in: api.slack.com → Your App → Basic Information → App-Level Tokens
# (Create one with connections:write scope if you haven't already)
SLACK_APP_TOKEN=xapp-your-token-here

# Ollama server URL (default is local)
OLLAMA_URL=http://localhost:11434

# The Ollama model to use for all AI responses
DEFAULT_MODEL=gemma3:4b
