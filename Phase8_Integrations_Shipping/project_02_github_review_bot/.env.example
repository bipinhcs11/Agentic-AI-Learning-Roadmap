# ─────────────────────────────────────────────────────────────────────────────
# GitHub Code Review Bot — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# GitHub Personal Access Token (classic or fine-grained)
# Required scopes: repo (or just: pull_requests:read + pull_requests:write)
# Create at: https://github.com/settings/tokens
# Leave empty to test with public repos (rate-limited to 60 req/hour)
GITHUB_TOKEN=ghp_your_token_here

# The secret you configured in your GitHub webhook settings.
# Must match exactly — any random string works, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# Ollama server URL (default is local)
OLLAMA_URL=http://localhost:11434

# The Ollama model to use for code review
DEFAULT_MODEL=gemma3:4b
